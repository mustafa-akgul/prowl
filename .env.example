# ──────────────────────────────────────────────
# AI Code Review Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# Google Gemini API key (required)
GEMINI_API_KEY=

# GitHub personal access token and target repository (required)
GITHUB_TOKEN=
GITHUB_REPO=org/repo-name

# Jira connection details (required for Jira integration)
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Jira status to transition tickets into after review (default: In Review)
JIRA_REVIEW_STATUS=In Review

# Jira custom field that stores acceptance criteria (default: customfield_10001)
# Override this if your Jira instance uses a different field ID.
# JIRA_AC_FIELD=customfield_10001

# ──────────────────────────────────────────────
# Stage 2: RAG Corporate Knowledge
# ──────────────────────────────────────────────
# (Optional) Use 'sentence_transformer' for better semantic search, mostly if using multiple languages
# RAG_EMBEDDING_PROVIDER=sentence_transformer
# RAG_MODEL_NAME=all-MiniLM-L6-v2

# ──────────────────────────────────────────────
# Stage 3: Async Task Queue & Webhooks
# ──────────────────────────────────────────────
# Redis connection string for Celery background tasks
REDIS_URL=redis://localhost:6379/0

# GitHub Webhook signature secret to verify payloads
# GITHUB_WEBHOOK_SECRET=your_super_secret_string

# ──────────────────────────────────────────────
# Stage 4: Notifications & Reporting
# ──────────────────────────────────────────────
# SMTP Mail Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=AI Code Review <no-reply@domain.com>
# REVIEW_EMAIL_RECIPIENTS=team@domain.com,dev@domain.com

# Slack/Teams Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://domain.webhook.office.com/webhookb2/...
